{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "required": ["id", "customerId", "type", "balance"],
    "properties": {
      "id": {
        "type": "integer"
      },
      "customerId": {
        "type": "integer"
      },
      "type": {
        "type": "string"
      },
      "balance": {
        "type": "number"
      }
    },
    "additionalProperties": true
  }
}